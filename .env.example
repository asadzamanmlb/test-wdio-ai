# ── QA Dashboard auth (login / RBAC by testcase folder: webTv, optools, coreApp) ──
# DASHBOARD_AUTH_DISABLED=1          # skip login (dev only)
# DASHBOARD_JWT_SECRET=min-16-chars-secret-for-production
# DASHBOARD_ALLOW_SIGNUP=0           # disable public signup; only admins create users via Admin UI
# Users stored in dashboard/data/auth-users.json (gitignored). First signup becomes admin with all suites.

# Xray Cloud API credentials (from Jira Settings > Apps > Xray > API Keys)
XRAY_CLIENT_ID=your_client_id
XRAY_CLIENT_SECRET=your_client_secret

# Optional: default issue key to fetch
XRAY_ISSUE_KEY=WSTE-796

# WDIO: red outline before clicks (default off). Enable for debugging: HIGHLIGHT_ELEMENTS=1
# HIGHLIGHT_ELEMENTS=1

# WebTV environments (use ENV=qa or ENV=beta when running tests)
WEBTV_QA=https://qa-gcp.mlb.com/tv
WEBTV_BETA=https://beta-gcp.mlb.com/tv

# WebTV login test credentials (use real credentials for automation)
TEST_EMAIL=your_email@example.com
TEST_PASSWORD=your_password

# BETA pre-auth (#username / #password gate on beta-gcp — required for most Sauce runs and any ENV=beta)
BETA_USERNAME=beta-user
BETA_PASSWORD=b3ta@mlb.com

# Sauce Labs (npm run test:sauce:qa) — https://app.saucelabs.com/user-settings
SAUCE_USERNAME=your_sauce_username
SAUCE_ACCESS_KEY=your_sauce_access_key
# @wdio/sauce-service region: SAUCE_WDIO_REGION=us | eu (or legacy SAUCE_REGION=eu-central-1 → eu)
# Optional: SAUCE_PLATFORM=Windows 11 | macOS 13 | Linux
# Safari on Sauce requires a Mac image (e.g. macOS 13). If SAUCE_PLATFORM is Windows, Safari still uses macOS 13 unless you set a macOS* value.
# Optional: SAUCE_BROWSER=chrome | firefox | edge
# Parallel Sauce VMs (1–8): SAUCE_MAX_INSTANCES=4  (or WDIO_MAX_INSTANCES from dashboard "Parallel")
# SAUCE_MAX_INSTANCES=4
# Optional: SAUCE_CAPTURE_PERFORMANCE=1  (sauce:options.capturePerformance)
# Optional: SAUCE_EXTENDED_DEBUGGING=0     (default on)
# Optional: DEVICE=WebTV                   (shown in Sauce job name with scenario + browser)
# Sauce Connect tunnel (off by default for public qa-gcp URLs): SAUCE_CONNECT=1
# Optional: SAUCE_TUNNEL_NAME=... SAUCE_TUNNEL_OWNER=...
