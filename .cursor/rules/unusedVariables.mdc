## Examples

### Good Examples
```javascript
// All variables are used
const { $, browser } = require('@wdio/globals');
const pageObject = require('../pageobjects/page.object.js');

const element = await $('selector');
await browser.url('/test-page');
await pageObject.clickElement(element);
```

### Bad Examples
```javascript
// Unused variables will be flagged
const { $, browser, unusedFunction } = require('@wdio/globals');
const unusedVariable = 'not used';
const anotherUnused = getData();

// Only using $ and browser
const element = await $('selector');
await browser.url('/test-page');
```

### Fixing Issues
```javascript
// Before (❌ Will be flagged):
const { $, browser, unusedFunction } = require('@wdio/globals');
const unusedVariable = 'not used';

// After (✅ Fixed):
const { $, browser } = require('@wdio/globals');
// Remove unused imports and variables
```

